# frozen_string_literal: true

# Other backends areprovided by templating.gemfile, as they are used by kettle-jem
# On JRuby only the :java and :ffi backends are available.
# On Truffleruby it seems that no backends are available (yet)
gem "ffi", require: false # DO NOT LOAD, because conflicts with MRI

gem "toml-rb"
gem "citrus"

platform :mri do
  # MRI only Parsers:
  gem "commonmarker"

  # Rust Backend
  gem "tree_stump", "~> 0.2" # ruby >= 3.1.0
end
